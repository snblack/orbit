<%= turbo_frame_tag "new_activity_form" do %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mt-4">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Предложить встречу</h2>

    <%= form_with model: [@pod, @activity] do |f| %>
      <div class="mb-4">
        <%= f.label :occurred_on, "Дата встречи", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :occurred_on,
            min: Date.today,
            class: "w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        <% if @activity.errors[:occurred_on].any? %>
          <p class="mt-1 text-sm text-red-600"><%= @activity.errors[:occurred_on].first %></p>
        <% end %>
      </div>

      <div class="flex justify-end">
        <%= f.submit "Предложить", class: "bg-indigo-600 text-white px-6 py-3 rounded-xl font-medium hover:bg-indigo-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
<% end %>
