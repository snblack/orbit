<%= form_with scope: :user, url: onboarding_step_path(step: "values"), method: :patch, data: { turbo_frame: "onboarding_step" } do |f| %>
  <h2 class="text-2xl font-bold text-gray-900 mb-6">Как вы общаетесь с людьми?</h2>

  <%# Социальный стиль %>
  <div class="mb-8">
    <h3 class="text-base font-semibold text-gray-700 mb-3">Ваш социальный стиль</h3>
    <div class="grid grid-cols-3 gap-3">
      <% [
        { value: "introvert",  icon: "🤫", label: "Интроверт",  desc: "Нужно время наедине" },
        { value: "ambivert",   icon: "🌗", label: "Амбиверт",   desc: "Зависит от ситуации" },
        { value: "extrovert",  icon: "🗣️",  label: "Экстраверт", desc: "Заряжаюсь от людей" },
      ].each do |opt| %>
        <label class="flex flex-col items-center gap-2 p-4 border-2 rounded-xl cursor-pointer text-center transition-all
                      border-gray-200 bg-white hover:border-indigo-300
                      has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50">
          <%= f.radio_button :social_style, opt[:value], checked: user.social_style == opt[:value], class: "sr-only" %>
          <span class="text-2xl"><%= opt[:icon] %></span>
          <span class="font-medium text-sm text-gray-900"><%= opt[:label] %></span>
          <span class="text-xs text-gray-500"><%= opt[:desc] %></span>
        </label>
      <% end %>
    </div>
  </div>

  <%# Цель дружбы %>
  <div class="mb-8">
    <h3 class="text-base font-semibold text-gray-700 mb-3">Что вы ищете в дружбе?</h3>
    <div class="grid grid-cols-2 gap-3">
      <% [
        { value: "support",      icon: "🤝", label: "Поддержка",  desc: "Рядом в трудные моменты" },
        { value: "growth",       icon: "🌱", label: "Развитие",   desc: "Расти вместе" },
        { value: "fun",          icon: "🎉", label: "Веселье",    desc: "Активность и приключения" },
        { value: "intellectual", icon: "🧠", label: "Интеллект",  desc: "Глубокие разговоры" },
      ].each do |opt| %>
        <label class="flex items-start gap-3 p-4 border-2 rounded-xl cursor-pointer transition-all
                      border-gray-200 bg-white hover:border-indigo-300
                      has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50">
          <%= f.radio_button :friendship_goal, opt[:value], checked: user.friendship_goal == opt[:value], class: "sr-only" %>
          <span class="text-xl"><%= opt[:icon] %></span>
          <span>
            <span class="block font-medium text-sm text-gray-900"><%= opt[:label] %></span>
            <span class="block text-xs text-gray-500"><%= opt[:desc] %></span>
          </span>
        </label>
      <% end %>
    </div>
  </div>

  <%# Уровень открытости %>
  <div class="mb-8">
    <h3 class="text-base font-semibold text-gray-700 mb-3">Насколько открыты с новыми людьми?</h3>
    <div class="grid grid-cols-3 gap-3">
      <% [
        { value: "surface",  label: "Поверхностно", desc: "Лёгкие темы" },
        { value: "moderate", label: "Умеренно",     desc: "Со временем" },
        { value: "deep",     label: "Глубоко",      desc: "Сразу честно" },
      ].each do |opt| %>
        <label class="flex flex-col items-center gap-1 p-4 border-2 rounded-xl cursor-pointer text-center transition-all
                      border-gray-200 bg-white hover:border-indigo-300
                      has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50">
          <%= f.radio_button :openness_level, opt[:value], checked: user.openness_level == opt[:value], class: "sr-only" %>
          <span class="font-medium text-sm text-gray-900"><%= opt[:label] %></span>
          <span class="text-xs text-gray-500"><%= opt[:desc] %></span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="mt-8 flex justify-between">
    <%= link_to "← Назад", onboarding_step_path(step: "life_phase"),
        class: "text-gray-500 hover:text-gray-700 px-4 py-3 rounded-xl font-medium",
        data: { turbo_frame: "onboarding_step" } %>
    <%= f.submit "Далее →", class: "bg-indigo-600 text-white px-6 py-3 rounded-xl font-medium hover:bg-indigo-700 transition-colors" %>
  </div>
<% end %>
