<%= form_with scope: :user, url: onboarding_step_path(step: "media"), method: :patch, data: { turbo_frame: "onboarding_step" } do |f| %>
  <h2 class="text-2xl font-bold text-gray-900 mb-2">Добавьте фото и видео</h2>
  <p class="text-gray-500 mb-8">Необязательно — можно пропустить и добавить позже</p>

  <div class="space-y-4">
    <%# Фото %>
    <div class="p-6 border-2 border-dashed border-gray-300 rounded-xl text-center bg-gray-50">
      <div class="text-4xl mb-2">📷</div>
      <p class="font-medium text-gray-700">Фото профиля</p>
      <p class="text-sm text-gray-400 mt-1">Загрузка фото будет доступна в следующей версии</p>
    </div>

    <%# Видео %>
    <div class="p-6 border-2 border-dashed border-gray-300 rounded-xl text-center bg-gray-50">
      <div class="text-4xl mb-2">🎥</div>
      <p class="font-medium text-gray-700">Видео-представление (15 сек)</p>
      <p class="text-sm text-gray-400 mt-1">Загрузка видео будет доступна в следующей версии</p>
    </div>
  </div>

  <div class="mt-8 flex justify-between">
    <%= link_to "← Назад", onboarding_step_path(step: "location"),
        class: "text-gray-500 hover:text-gray-700 px-4 py-3 rounded-xl font-medium",
        data: { turbo_frame: "onboarding_step" } %>
    <%= f.submit "Завершить →", class: "bg-indigo-600 text-white px-6 py-3 rounded-xl font-medium hover:bg-indigo-700 transition-colors" %>
  </div>
<% end %>
