<%= form_with scope: :user, url: onboarding_step_path(step: "rhythm"), method: :patch, data: { turbo_frame: "onboarding_step" } do |f| %>
  <h2 class="text-2xl font-bold text-gray-900 mb-6">Ваш ритм жизни</h2>

  <%# Частота встреч %>
  <div class="mb-8">
    <h3 class="text-base font-semibold text-gray-700 mb-3">Как часто хотите встречаться?</h3>
    <div class="grid grid-cols-3 gap-3">
      <% [
        { value: "once_week",     label: "1 раз в неделю",  desc: "Неторопливо" },
        { value: "two_three_week", label: "2–3 раза",       desc: "Активно" },
        { value: "daily",         label: "Каждый день",     desc: "Очень близко" },
      ].each do |opt| %>
        <label class="flex flex-col items-center gap-1 p-4 border-2 rounded-xl cursor-pointer text-center transition-all
                      border-gray-200 bg-white hover:border-indigo-300
                      has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50">
          <%= f.radio_button :social_frequency, opt[:value], checked: user.social_frequency == opt[:value], class: "sr-only" %>
          <span class="font-medium text-sm text-gray-900"><%= opt[:label] %></span>
          <span class="text-xs text-gray-500"><%= opt[:desc] %></span>
        </label>
      <% end %>
    </div>
  </div>

  <%# Расписание %>
  <div class="mb-8">
    <h3 class="text-base font-semibold text-gray-700 mb-1">Когда вы обычно свободны?</h3>
    <p class="text-sm text-gray-500 mb-4">Отметьте удобные дни и время</p>

    <% days = [
      { key: "mon", label: "Пн" }, { key: "tue", label: "Вт" }, { key: "wed", label: "Ср" },
      { key: "thu", label: "Чт" }, { key: "fri", label: "Пт" }, { key: "sat", label: "Сб" },
      { key: "sun", label: "Вс" }
    ] %>
    <% times = [
      { key: "morning",   label: "Утро",   desc: "8–12" },
      { key: "afternoon", label: "День",   desc: "12–18" },
      { key: "evening",   label: "Вечер",  desc: "18–22" },
    ] %>

    <div class="overflow-x-auto">
      <table class="w-full text-center text-sm border-separate border-spacing-1">
        <thead>
          <tr>
            <th class="text-gray-400 font-normal w-16"></th>
            <% days.each do |day| %>
              <th class="text-gray-600 font-medium w-10"><%= day[:label] %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% times.each do |time| %>
            <tr>
              <td class="text-left pr-2">
                <span class="font-medium text-gray-700"><%= time[:label] %></span>
                <span class="block text-xs text-gray-400"><%= time[:desc] %></span>
              </td>
              <% days.each do |day| %>
                <% key = "#{day[:key]}_#{time[:key]}" %>
                <% checked = user.schedule_preference&.dig(key) == "1" %>
                <td>
                  <label class="flex items-center justify-center w-9 h-9 rounded-lg border-2 cursor-pointer mx-auto transition-all
                                border-gray-200 bg-white hover:border-indigo-300
                                has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-100">
                    <input type="checkbox" name="user[schedule_preference][<%= key %>]" value="1"
                           <%= "checked" if checked %>
                           class="sr-only">
                  </label>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-8 flex justify-between">
    <%= link_to "← Назад", onboarding_step_path(step: "values"),
        class: "text-gray-500 hover:text-gray-700 px-4 py-3 rounded-xl font-medium",
        data: { turbo_frame: "onboarding_step" } %>
    <%= f.submit "Далее →", class: "bg-indigo-600 text-white px-6 py-3 rounded-xl font-medium hover:bg-indigo-700 transition-colors" %>
  </div>
<% end %>
