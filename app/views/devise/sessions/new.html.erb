<div class="max-w-md mx-auto mt-12 px-4">
  <div class="bg-white rounded-2xl shadow-md p-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Войти</h1>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, "Email", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            placeholder: "your@email.com",
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>

      <div class="mb-6">
        <%= f.label :password, "Пароль", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
            placeholder: "Минимум 6 символов",
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>

      <%= f.submit "Войти", class: "w-full bg-indigo-600 text-white px-6 py-3 rounded-xl font-medium hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <% end %>

    <div class="mt-4 flex flex-col gap-2 text-center">
      <%= link_to "Нет аккаунта? Зарегистрироваться", new_user_registration_path, class: "text-sm text-indigo-600 hover:underline" %>
      <%= link_to "Забыли пароль?", new_user_password_path, class: "text-sm text-indigo-600 hover:underline" %>
    </div>
  </div>
</div>
