<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Orbit" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Orbit">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <% if user_signed_in? %>
      <meta name="current-user-id" content="<%= current_user.id %>">
    <% end %>
  </head>

  <body class="bg-gray-50 text-gray-900">

    <%# Navbar %>
    <nav class="bg-white border-b border-gray-200" data-controller="navbar">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">

          <%# Логотип %>
          <div class="flex items-center">
            <%= link_to root_path, class: "text-xl font-bold text-indigo-600" do %>
              Orbit
            <% end %>
          </div>

          <%# Десктоп меню %>
          <div class="hidden sm:flex sm:items-center sm:gap-4">
            <% if user_signed_in? %>
              <span class="text-sm text-gray-600"><%= current_user.email %></span>
              <% if (my_pod = current_user.pods.order(created_at: :desc).first) %>
                <%= link_to "Мой Pod", pod_path(my_pod), class: "text-sm text-indigo-600 font-medium hover:text-indigo-800" %>
              <% end %>
              <%= link_to "Выйти", destroy_user_session_path, data: { turbo_method: :delete },
                  class: "text-sm text-gray-600 hover:text-indigo-600" %>
            <% else %>
              <%= link_to "Войти", new_user_session_path,
                  class: "text-sm text-gray-600 hover:text-indigo-600" %>
              <%= link_to "Регистрация", new_user_registration_path,
                  class: "text-sm bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700" %>
            <% end %>
          </div>

          <%# Бургер (мобиле) %>
          <div class="flex items-center sm:hidden">
            <button data-action="navbar#toggle" class="text-gray-500 hover:text-gray-700 p-2">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>

        </div>
      </div>

      <%# Мобильное меню %>
      <div class="hidden sm:hidden" data-navbar-target="menu">
        <div class="px-4 py-3 space-y-2 border-t border-gray-200">
          <% if user_signed_in? %>
            <p class="text-sm text-gray-600"><%= current_user.email %></p>
            <% if (my_pod = current_user.pods.order(created_at: :desc).first) %>
              <%= link_to "Мой Pod", pod_path(my_pod), class: "block text-sm text-indigo-600 font-medium hover:text-indigo-800 py-1" %>
            <% end %>
            <%= link_to "Выйти", destroy_user_session_path, data: { turbo_method: :delete },
                class: "block text-sm text-gray-600 hover:text-indigo-600 py-1" %>
          <% else %>
            <%= link_to "Войти", new_user_session_path,
                class: "block text-sm text-gray-600 hover:text-indigo-600 py-1" %>
            <%= link_to "Регистрация", new_user_registration_path,
                class: "block text-sm text-indigo-600 font-medium py-1" %>
          <% end %>
        </div>
      </div>
    </nav>

    <%# Flash-сообщения %>
    <%= render 'shared/flash' %>

    <%# Контент %>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

  </body>
</html>
