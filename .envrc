PATH_add "$HOME/.local/share/mise/installs/ruby/3.4.8/bin"

set -a
test -f .env && . .env
test -f .env.local && . .env.local
set +a

if [ -z "${PORT:-}" ] && command -v port-selector >/dev/null 2>&1; then
  port="$(port-selector 2>/dev/null | tr -d '[:space:]')"
  if printf '%s' "$port" | grep -Eq '^[0-9]+$'; then
    export PORT="$port"
  fi
fi
